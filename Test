-- NotificationModule.lua

local NotificationModule = {}

function NotificationModule.createNotification(title, content, time)
    -- Cria o ScreenGui para segurar a notificação
    local screenGui = Instance.new("ScreenGui")
    screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    screenGui.ResetOnSpawn = false

    -- Cria o Frame da notificação
    local notificationFrame = Instance.new("Frame")
    notificationFrame.Size = UDim2.new(0.3, 0, 0.13, 0)
    notificationFrame.Position = UDim2.new(1, 20, 0.85, 0) -- Inicialmente fora da tela, parte inferior direita
    notificationFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Fundo preto
    notificationFrame.BorderSizePixel = 0
    notificationFrame.AnchorPoint = Vector2.new(1, 1)
    notificationFrame.Parent = screenGui

    -- Adiciona uma borda amarela ao Frame
    local border = Instance.new("UIStroke")
    border.Thickness = 2 -- Espessura da borda
    border.Color = Color3.fromRGB(255, 255, 0) -- Cor amarela
    border.Parent = notificationFrame

    -- Adiciona bordas arredondadas
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = notificationFrame

    -- Cria o título da notificação
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 0.3, 0)
    titleLabel.Position = UDim2.new(0, 10, 0, 5)
    titleLabel.Text = title
    titleLabel.TextColor3 = Color3.new(1, 1, 1)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextSize = 18
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notificationFrame

    -- Cria o conteúdo da notificação
    local contentLabel = Instance.new("TextLabel")
    contentLabel.Size = UDim2.new(1, -20, 0.6, 0)
    contentLabel.Position = UDim2.new(0, 10, 0.3, 0)
    contentLabel.Text = content
    contentLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    contentLabel.BackgroundTransparency = 1
    contentLabel.TextSize = 14
    contentLabel.Font = Enum.Font.Gotham
    contentLabel.TextWrapped = true
    contentLabel.TextXAlignment = Enum.TextXAlignment.Left
    contentLabel.Parent = notificationFrame

    -- Animação de entrada (suave)
    notificationFrame:TweenPosition(UDim2.new(0.98, 0, 0.85, 0), 'Out', 'Quint', 0.5, true)

    -- Aguarda o tempo definido antes de desaparecer
    wait(time or 5)

    -- Animação de saída (suave)
    notificationFrame:TweenPosition(UDim2.new(1.2, 0, 0.85, 0), 'In', 'Quint', 0.5, true)

    -- Remove a notificação após a animação
    wait(0.5)
    screenGui:Destroy()
end

return NotificationModule
