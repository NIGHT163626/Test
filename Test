-- Callbacks Globais
_G.GetKeyCallback = function()
    setclipboard("Link para obter a chave")
    print("Get Key clicado!")
end

_G.CheckKeyCallback = function(enteredKey)
    local validKey = "YourRealKey"
    if enteredKey == validKey then
        print("Chave correta!")
        TextBox.PlaceholderText = "Key Valida!"
        TextBox.Text = ""
        wait(1)
        ScreenGui:Destroy()
        loadstring(game:HttpGet('https://pastebin.com/raw/YSL3xKYU'))()
    else
        print("Chave inválida. Tente novamente.")
        TextBox.PlaceholderText = "Key Invalida."
        TextBox.Text = ""
        wait(1)
        TextBox.PlaceholderText = "Enter Key..."
        TextBox.Text = ""
    end
end

_G.DiscordCallback = function()
    setclipboard("https://discord.gg/seuLink")
    print("Link do Discord copiado!")
end

-- Conectando os eventos aos callbacks
GetKey.MouseButton1Click:Connect(function()
    if _G.GetKeyCallback then
        _G.GetKeyCallback()
    end
end)

CheckKey.MouseButton1Click:Connect(function()
    local enteredKey = TextBox.Text
    if _G.CheckKeyCallback then
        _G.CheckKeyCallback(enteredKey)
    end
end)

DiscordButton.MouseButton1Click:Connect(function()
    if _G.DiscordCallback then
        _G.DiscordCallback()
    end
end)

-- Inicialize o valor de _G.Destroi
_G.Destroi = false

-- Função para destruir a GUI quando _G.Destroi é verdadeiro
spawn(function()
    while wait(0.1) do  -- Verificação a cada 0.1 segundos
        if _G.Destroi then
            ScreenGui:Destroy()
            _G.Destroi = false  -- Reseta o valor para evitar chamadas futuras
            break
        end
    end
end)
