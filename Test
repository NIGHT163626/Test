-- Nome do Módulo
local MyGuiLibrary = {}

-- Variáveis Globais
local ElementFunction = {}
local ItemParent = script.Parent -- Ajuste conforme a hierarquia do seu projeto

-- Função para criar a GUI
function MyGuiLibrary:CreateGui()
    local ScreenGui = Instance.new("ScreenGui")
    local MainFrame = Instance.new("Frame")

    ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

    MainFrame.Size = UDim2.new(0.5, 0, 0.5, 0)
    MainFrame.Position = UDim2.new(0.25, 0, 0.25, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    MainFrame.BackgroundTransparency = 0.5
    MainFrame.Parent = ScreenGui

    ItemParent = MainFrame -- Definindo o pai como o MainFrame
end

-- Função para adicionar um Label
function ElementFunction:AddLabel(Text, Width, Height)
    local LabelWidth = Width or 1
    local LabelHeight = Height or 200

    local LabelFrame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 5), {
        Size = UDim2.new(LabelWidth, 0, 0, LabelHeight),
        BackgroundTransparency = 0.7,
        Parent = ItemParent
    }), {
        AddThemeObject(SetProps(MakeElement("Label", Text, 22), {
            Size = UDim2.new(1, -12, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            Font = Enum.Font.GothamBold,
            Name = "Content"
        }), "Text"),
        AddThemeObject(MakeElement("Stroke"), "Stroke")
    }), "Second")

    return LabelFrame.Content -- Retornar o Label para manipulação posterior
end

-- Função para adicionar um Botão
function ElementFunction:AddButton(Text, Width, Height, Callback)
    local ButtonWidth = Width or 0.3
    local ButtonHeight = Height or 50

    local ButtonFrame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 5), {
        Size = UDim2.new(ButtonWidth, 0, 0, ButtonHeight),
        BackgroundTransparency = 0.5,
        Parent = ItemParent
    }), {
        AddThemeObject(SetProps(MakeElement("Label", Text, 22), {
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            Font = Enum.Font.GothamBold,
            TextColor3 = Color3.fromRGB(0, 0, 0),
            Name = "Content"
        }), "Text"),
        AddThemeObject(MakeElement("Stroke"), "Stroke")
    }), "Second")

    ButtonFrame.MouseButton1Click:Connect(function()
        if Callback then
            Callback()
        end
    end)

    return ButtonFrame -- Retornar o botão para manipulação posterior
end

-- Função para adicionar uma Caixa de Texto
function ElementFunction:AddTextBox(PlaceholderText, Width, Height)
    local TextBoxWidth = Width or 0.8
    local TextBoxHeight = Height or 50

    local TextBoxFrame = AddThemeObject(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 5), {
        Size = UDim2.new(TextBoxWidth, 0, 0, TextBoxHeight),
        BackgroundTransparency = 0.5,
        Parent = ItemParent
    }), "TextBox")

    local TextBox = AddThemeObject(SetProps(MakeElement("TextBox", "", 22), {
        Size = UDim2.new(1, -12, 1, 0),
        Position = UDim2.new(0, 6, 0, 0),
        PlaceholderText = PlaceholderText or "Digite aqui...",
        BackgroundColor3 = Color3.fromRGB(240, 240, 240),
        TextColor3 = Color3.fromRGB(0, 0, 0),
        TextScaled = true,
        Name = "Content"
    }), "Text")

    return TextBoxFrame, TextBox -- Retornar ambos para manipulação posterior
end

-- Adicionando a tabela ElementFunction ao MyGuiLibrary
MyGuiLibrary.ElementFunction = ElementFunction

-- Retornar o módulo
return MyGuiLibrary
