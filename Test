-- Notification Module
local NotificationModule = {}

-- Função para criar a notificação
function NotificationModule:MakeNotification(NotificationConfig)
	local screenGui = Instance.new("ScreenGui")
	local NotificationHolder = Instance.new("Frame")
	local NotificationFrame = Instance.new("Frame")
	
	screenGui.Name = "NotificationGui"
	screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

	NotificationHolder.Size = UDim2.new(0, 300, 0, 0)
	NotificationHolder.Position = UDim2.new(0.5, -150, 0.1, 0)
	NotificationHolder.BackgroundTransparency = 1
	NotificationHolder.Parent = screenGui

	NotificationFrame.Size = UDim2.new(1, 0, 0, 50)
	NotificationFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	NotificationFrame.BorderSizePixel = 0
	NotificationFrame.Parent = NotificationHolder

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Size = UDim2.new(1, 0, 0.5, 0)
	TitleLabel.Text = NotificationConfig.Name or "Notification"
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Parent = NotificationFrame

	local ContentLabel = Instance.new("TextLabel")
	ContentLabel.Size = UDim2.new(1, 0, 0.5, 0)
	ContentLabel.Position = UDim2.new(0, 0, 0.5, 0)
	ContentLabel.Text = NotificationConfig.Content or "Notification content..."
	ContentLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
	ContentLabel.BackgroundTransparency = 1
	ContentLabel.Parent = NotificationFrame

	-- Animação de aparição
	NotificationFrame:TweenPosition(UDim2.new(0.5, -150, 0.1, 0), "Out", "Quad", 0.3, true)

	-- Remove a notificação após um certo tempo
	wait(NotificationConfig.Time or 5)
	NotificationFrame:TweenPosition(UDim2.new(0.5, -150, -0.2, 0), "Out", "Quad", 0.3, true, function()
		screenGui:Destroy()
	end)
end

-- Retorna o módulo
return NotificationModule
