local TweenService = game:GetService("TweenService")

-- Criando a interface do usuário
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

local NotificationHolder = Instance.new("Frame")
NotificationHolder.Size = UDim2.new(0, 300, 1, -25)
NotificationHolder.Position = UDim2.new(1, -25, 1, -25)
NotificationHolder.AnchorPoint = Vector2.new(1, 1)
NotificationHolder.BackgroundTransparency = 1
NotificationHolder.Parent = ScreenGui

-- Função para criar elementos
local function MakeElement(elementType, properties)
    local element = Instance.new(elementType)
    for prop, value in pairs(properties) do
        element[prop] = value
    end
    return element
end

-- Função de notificação
local NightLib = {}

function NightLib:MakeNotification(NotificationConfig)
    spawn(function()
        NotificationConfig.Name = NotificationConfig.Name or "Notification"
        NotificationConfig.Content = NotificationConfig.Content or "Test"
        NotificationConfig.Image = NotificationConfig.Image or "rbxassetid://83913533460895"
        NotificationConfig.Time = NotificationConfig.Time or 15

        local NotificationParent = MakeElement("Frame", {
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = NotificationHolder
        })

        local NotificationFrame = MakeElement("Frame", {
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(1, -55, 0, 0),
            BackgroundTransparency = 0,
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = NotificationParent,
            BackgroundColor3 = Color3.fromRGB(25, 25, 25),
        })

        -- Criação dos elementos da notificação
        MakeElement("ImageLabel", {
            Size = UDim2.new(0, 20, 0, 20),
            ImageColor3 = Color3.fromRGB(240, 240, 240),
            Image = NotificationConfig.Image,
            Parent = NotificationFrame,
        })

        MakeElement("TextLabel", {
            Size = UDim2.new(1, -30, 0, 20),
            Position = UDim2.new(0, 30, 0, 0),
            Font = Enum.Font.GothamBold,
            Text = NotificationConfig.Name,
            Parent = NotificationFrame,
        })

        MakeElement("TextLabel", {
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(0, 0, 0, 25),
            Font = Enum.Font.GothamSemibold,
            Text = NotificationConfig.Content,
            RichText = true,
            AutomaticSize = Enum.AutomaticSize.Y,
            TextColor3 = Color3.fromRGB(200, 200, 200),
            TextWrapped = true,
            Parent = NotificationFrame,
        })

        -- Animação de entrada
        TweenService:Create(NotificationFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 0, 0)}):Play()

        wait(NotificationConfig.Time - 0.88)

        -- Animação de saída
        TweenService:Create(NotificationFrame, TweenInfo.new(0.8, Enum.EasingStyle.Quint), {BackgroundTransparency = 0.6}):Play()
        wait(0.3)
        NotificationFrame:Destroy()
    end)
end    

return NightLib
