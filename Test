local PoisonLib = {}

-- Função para criar a janela principal
function PoisonLib:MakeWindow(config)
    local window = {} -- Guarda referências para adicionar componentes depois

    -- Configuração da interface principal (como o Frame)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 400, 0, 300)
    Frame.Position = UDim2.new(0.5, 0, 0.5, 0)
    Frame.AnchorPoint = Vector2.new(0.5, 0.5)
    Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Frame.BorderSizePixel = 0
    Frame.Active = true
    Frame.Draggable = true
    Frame.Parent = ScreenGui
    
    -- Guarda a referência do Frame principal
    window.Frame = Frame

    -- Função para adicionar um botão à janela
    function window:AddButton(config)
        local ButtonFrame = Instance.new("Frame")
        ButtonFrame.Size = UDim2.new(0.35, 0, 0.15, 0)
        ButtonFrame.BackgroundTransparency = 1
        ButtonFrame.Parent = Frame
        
        local ButtonStroke = Instance.new("UIStroke")
        ButtonStroke.Thickness = 2
        ButtonStroke.Color = Color3.fromRGB(255, 255, 0) -- Amarelo
        ButtonStroke.Parent = ButtonFrame

        local Button = Instance.new("TextButton")
        Button.Size = UDim2.new(1, 0, 1, 0)
        Button.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        Button.Text = config.Name or "Button"
        Button.TextSize = 18
        Button.Font = Enum.Font.GothamBold
        Button.TextColor3 = Color3.fromRGB(150, 150, 150)
        Button.Parent = ButtonFrame

        Button.MouseButton1Click:Connect(function()
            if config.Callback then
                config.Callback()
            end
        end)

        return Button
    end

    -- Função para adicionar um textbox à janela
    function window:AddTextbox(config)
        local TextBoxFrame = Instance.new("Frame")
        TextBoxFrame.Size = UDim2.new(0.8, 0, 0.2, 0)
        TextBoxFrame.BackgroundTransparency = 1
        TextBoxFrame.Parent = Frame

        local TextBoxStroke = Instance.new("UIStroke")
        TextBoxStroke.Thickness = 2 -- Espessura da borda
        TextBoxStroke.Color = Color3.fromRGB(255, 255, 0) -- Amarelo
        TextBoxStroke.Parent = TextBoxFrame

        local TextBox = Instance.new("TextBox")
        TextBox.Size = UDim2.new(1, 0, 1, 0)
        TextBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        TextBox.PlaceholderText = config.Name or "Enter text..."
        TextBox.Text = config.Default or ""
        TextBox.TextSize = 18
        TextBox.Font = Enum.Font.GothamBold
        TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        TextBox.Parent = TextBoxFrame

        TextBox.FocusLost:Connect(function(enterPressed)
            if enterPressed and config.Callback then
                config.Callback(TextBox.Text)
            end
        end)

        return TextBox
    end

    return window
end

return PoisonLib
